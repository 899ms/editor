{
  "name": "@pascal-app/i18n",
  "version": "0.1.0",
  "description": "Shared internationalization runtime and resources for Pascal UI packages",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsgo --build --watch",
    "test": "bun test",
    "check-types": "tsgo --noEmit",
    "prepublishOnly": "bun run build \u0026\u0026 bun test"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "dependencies": {
    "i18next": "^25.0.0",
    "react-i18next": "^16.0.0"
  },
  "devDependencies": {
    "@pascal/typescript-config": "*",
    "@types/bun": "^1.3.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "6.0.3"
  },
  "keywords": [
    "pascal",
    "i18n",
    "localization",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pascalorg/editor.git",
    "directory": "packages/i18n"
  },
  "license": "MIT"
}
