    "roofSegment": "A single pitched plane of a parent roof.",
    "scan": "A captured LiDAR or photogrammetry mesh imported as a scene reference.",
    "shelf": "A configurable shelving unit. Items host on each row.",
    "site": "The top-level container holding buildings, zones, and the property boundary.",
    "skylight": "Framed glass opening on a roof segment.",
    "slab": "A polygon-bounded floor surface that hosts items on top.",
    "solarPanel": "Grid of photovoltaic panels mounted on a roof segment.",
