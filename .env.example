# Local SQLite scene storage. Set this when the default user data directory is unavailable.
# Use the same value for the editor and MCP server when they should share scenes.
# PASCAL_DATA_DIR=./.data

# Optional environment variables — the editor works without any of these

# Google Maps API key (enables address search)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Dev server port (default: 3000)
# PORT=3000
